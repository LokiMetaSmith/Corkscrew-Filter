FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      nut;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -1 0 0 0 0];

internalField   uniform 1e-7;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           $internalField;
    }

    clean_outlet
    {
        type            zeroGradient;
    }

    dust_outlet
    {
        type            zeroGradient;
    }

    corkscrew
    {
        type            nutkWallFunction;
        value           $internalField;
    }

    walls
    {
        type            nutkWallFunction;
        value           $internalField;
    }

    ".*"
    {
        type            zeroGradient;
    }

}
